n, PlatformUserCreateInput, PlatformUser } from '@enterprise-commerce/core/platform/types';\nimport axios from 'axios';\nimport { Request, Response } from 'express';\nimport jwt from 'jsonwebtoken';\n\nconst registerUser = async (input: PlatformUserCreateInput): Promise<Pick<PlatformUser, \"id\"> | undefined | null> => {\n  // ToDo: Implement the registerUser function\n  return null\n};\n\nconst loginUser = async (input: PlatformUserCreateInput) => {\n  // ToDo: Implement the loginUser function (someone else is working on it)\n  const user = {id: null} // replace this line\n\n\n  // The following lines can be left unchanged because the output is expected to be a JWT token and an expiresAt value\n  const accessToken = jwt.sign({ id: user?.id }, process.env.JWT_SECRET || \"no_key_set\" as string, { expiresIn: '1h' });\n  const expiresAt = new Date(Date.now() + 3600 * 1000).toISOString(); // 3600 seconds = 1 hour\n  return { accessToken, expiresAt };\n};\n\nconst getUser = async (accessToken: string): Promise<PlatformUser | undefined | null> => {\n  try {\n    if(accessToken != \"\") {\n      const { data } = await axios.get('http://localhost:3001/me', {\n        headers: {\n          Authorization: `Bearer ${accessToken}`,\n        },\n      });\n\n      return data.user;\n    } else {\n      return null\n    }\n  } catch (error) {\n    console.error(error);\n    // Handle error\n    return null;\n  }\n};\n\nexport default {\n  registerUser,\n  loginUser,\n  getUser\n};","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773759265955,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documentId":21,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773759275171,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773759294499,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"ActiveEditorChangeEvent","eventTime":1773759312303,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"ActiveEditorChangeEvent","eventTime":1773759339044,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/app/actions/user.actions.ts","documentId":20,"operation":"focus","rangeOffset":"0","rangeLength":"0","ran