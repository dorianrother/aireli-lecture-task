eLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773760091607,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773760215903,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"replace","value":"    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required.' });\n      return;\n    }\n\n    const newUser: PlatformUser = {\n      id: '',\n      email,\n      password,\n    };\n\n    const createdUser = await createUser(newUser);\n\n    res.status(201).json({\n      user: {\n        id: createdUser.id,\n        email: createdUser.email,\n      },\n    });\n  } catch (error: any) {\n    console.error(error);\n    if (error?.message?.includes('UNIQUE constraint failed: users.email')) {\n      res.status(409).json({ message: 'Email already in use.' });\n      return;\n    }\n    res.status(500).json({ message: error?.message || 'Registration failed.' });\n  }\n","rangeOffset":"359","rangeLength":"289","rangestart_line":"9","rangestart_character":"0","rangeend_line":"26","rangeend_character":"1"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773760216158,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773760221621,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773760224417,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"ActiveEditorChangeEvent","eventTime":1773760224421,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773760230350,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"replace","value":"PlatformUser> => {\n  const db = await openDb();\n  const hashedPassword = await bcrypt.hash(newUser.password || '', 10);\n\n  const result = await db.run(\n    `INSERT INTO users (email, password, acceptsMarketing, createdAt, updatedAt) VALUES (?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)`,\n    newUser.email,\n    hashedPassword,\n    0\n  );\n\n  const createdUser = await db.get<{ id: number; email: string; password: string }>('SELECT id, email, password FROM users WHERE id = ?', result.lastID);\n  await db.close();\n\n  if (!createdUser) {\n    throw new Error('Failed to create user');\n  }\n\n  return {\n    id: String(createdUser.id),\n    email: createdUser.email,\n    password: createdUser.password,\n  };","rangeOffset":"297","rangeLength":"548","rangestart_line":"7","rangestart_character":"65","rangeend_line":"25","rangeend_character":"2"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773760230441,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773760242642,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowBlurred","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"ob