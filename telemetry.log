/controllers/auth.controllers.ts","documentId":13,"operation":"replace","value":"try {\n    const { email, password } = req.body;\n    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required.' });\n      return;\n    }\n\n    const newUser: PlatformUser = {\n      id: '',\n      email,\n      password,\n    };\n\n    const createdUser = await createUser(newUser);\n\n    const accessToken = jwt.sign({ id: createdUser.id }, process.env.JWT_SECRET || 'no_key_set', { expiresIn: '1h' });\n\n    res.status(201).json({\n      user: {\n        id: createdUser.id,\n        email: createdUser.email,\n      },\n      accessToken,\n    });\n  } catch (error: any) {\n    if (error?.message?.includes('UNIQUE constraint failed: users.email')) {\n      res.status(409).json({ message: 'Email already in use.' });\n      return;\n    }\n    console.error(error);\n    res.status(500).json({ message: error?.message || 'Registration failed' });\n  }","rangeOffset":"311","rangeLength":"273","rangestart_line":"7","rangestart_character":"2","rangeend_line":"22","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773757213696,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773757219275,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/web/clients/internalClient.ts","documen