ocus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"ActiveEditorChangeEvent","eventTime":1773755862859,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"focus","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773755961911,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"replace","value":"async (newUser: PlatformUser): Promise<PlatformUser> => {\n  const db = await openDb();\n\n  const hashedPassword = await bcrypt.hash(newUser.password, 10);\n\n  const { lastID } = await db.run(\n    `INSERT INTO users (acceptsMarketing, displayName, email, firstName, lastName, phone, tags, password) VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n    newUser.acceptsMarketing ? 1 : 0,\n    newUser.displayName || null,\n    newUser.email,\n    newUser.firstName || null,\n    newUser.lastName || null,\n    newUser.phone || null,\n    Array.isArray(newUser.tags) ? newUser.tags.join(',') : newUser.tags || null,\n    hashedPassword\n  );\n\n  const createdUser = await db.get<PlatformUser>('SELECT * FROM users WHERE id = ?', lastID);\n  await db.close();\n\n  if (!createdUser) {\n    throw new Error('Failed to create user');\n  }\n\n  return createdUser;\n};","rangeOffset":"258","rangeLength":"71","rangestart_line":"7","rangestart_character":"26","rangeend_line":"9","rangeend_character":"38"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773755962134,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773755967280,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"replace","value":"try {\n    const { email, password, firstName, lastName, displayName, phone, acceptsMarketing, tags } = req.body;\n\n    if (!email || !password) {\n      res.status(400).json({ message: 'Email and password are required.' });\n      return;\n    }\n\n    const newUser: PlatformUser = {\n      id: null,\n      email,\n      password,\n      firstName: firstName || null,\n      lastName: lastName || null,\n      displayName: displayName || null,\n      phone: phone || null,\n      acceptsMarketing: acceptsMarketing || false,\n      tags: tags || null\n    };\n\n    const createdUser = await createUser(newUser);\n\n    const token = jwt.sign({ id: createdUser.id }, process.env.JWT_SECRET || 'no_key_set', { expiresIn: '1h' });\n\n    res.status(201).json({\n      user: {\n        id: createdUser.id,\n        email: createdUser.email,\n        firstName: createdUser.firstName,\n        lastName: createdUser.lastName,\n        displayName: createdUser.displayName,\n      },\n      token\n    });\n  } catch (err: any) {\n    res.status(500).json({ message: err.message || 'Unable to create user' });\n  }","rangeOffset":"280","rangeLength":"149","rangestart_line":"6","rangestart_character":"2","rangeend_line":"14","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentSaveEvent","eventTime":1773755967427,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/controllers/auth.controllers.ts","documentId":13,"operation":"save","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"WindowStateChangeEvent","eventTime":1773755973926,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"","documentId":0,"operation":"windowFocused","rangeOffset":"0","rangeLength":"0","rangestart_line":"0","rangestart_character":"0","rangeend_line":"0","rangeend_character":"0"},{"codespaceName":"obscure-fortnight-pjv56r65w4w6hr46p","eventName":"DocumentChangeEvent","eventTime":1773755995587,"sessionId":"5ee5da8e-3a2f-4f4e-bdfb-64f3d47d92f01773754724998","machineId":"8d1e618869284eb35cf16b53c41b828b010ce5d7d655b0154d57ef1631816079","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":12,"operation":"replace","value":"  const hashedPassword = await bcrypt.hash(newUser.password || '', 10);\n\n  const result = await db.run(\n    `INSERT INTO users (email, password, acceptsMarketing, createdAt, updatedAt) VALUES (?, ?, ?, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)`,\n    newUser.email,\n    hashedPassword,\n    0\n  );\n\n  const createdUser = await db.get<PlatformUser>('SELECT id, email, password FROM users WHERE id = ?', result.lastID);\n  await db.close();\n\n  if (